import {
  "moonbitlang/core/debug",
  "conglinyizhi/better-edit-tools-mcp/chip",
  "conglinyizhi/better-edit-tools-mcp/common",
  "conglinyizhi/better-edit-tools-mcp/error",
  "conglinyizhi/better-edit-tools-mcp/snapshot",
  "conglinyizhi/better-edit-tools-mcp/testutil",
  "moonbitlang/core/env",
  "moonbitlang/core/json",
  "moonbitlang/core/random",
  "moonbitlang/x/fs",
}

options(
  "native-stub": [ "atomic_native.c" ],
  // testutil 仅在测试文件中使用
  warnings: "-unused_package",
  targets: {
    "atomic_native.mbt": [ "native", "llvm" ],
    "atomic_js.mbt": [ "js" ],
    "atomic_wasm.mbt": [ "wasm", "wasm-gc" ],
    "atomic_utf8.mbt": [ "wasm", "wasm-gc", "js" ],
  },
)
