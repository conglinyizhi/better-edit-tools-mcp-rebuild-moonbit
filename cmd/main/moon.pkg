import {
  "conglinyizhi/better-edit-tools-mcp/server",
  "conglinyizhi/better-edit-tools-mcp/read",
  "conglinyizhi/better-edit-tools-mcp/write",
  "conglinyizhi/better-edit-tools-mcp/edit",
  "conglinyizhi/better-edit-tools-mcp/check",
  "conglinyizhi/better-edit-tools-mcp/common",
  "conglinyizhi/better-edit-tools-mcp/error",
  "moonbitlang/x/sys",
  "moonbitlang/x/fs",
  "moonbitlang/core/strconv",
}

options(
  "is-main": true,
  targets: {
    "cli.mbt": [ "native", "llvm" ],
    "cli_wbtest.mbt": [ "native", "llvm" ],
  },
  // cli.mbt 仅在 native 下编译，因此这些导入在其他 target 上会出现 unused_package 警告。
  warnings: "-unused_package",
)
